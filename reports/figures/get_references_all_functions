// Dependency Graph
digraph {
	graph [compound=true concentrate=true rankdir=LR ranksep=0.4 style=filled]
	node [fillcolor="#ffffff"]
	references_on_disk [label=<<b>references_on_disk</b><br /><br /><i>False</i>> fontname=Helvetica shape=note style=filled]
	error_references [label=<<b>error_references</b><br /><br /><i>list</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	database [label=<<b>database</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	save_references_from_open_citations [label=<<b>save_references_from_open_citations</b><br /><br /><i>save_references_from_open_citations()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	cleaned_dois [label=<<b>cleaned_dois</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetched_references_df [label=<<b>fetched_references_df</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetched_references [label=<<b>fetched_references</b><br /><br /><i>dict</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	save_error_references [label=<<b>save_error_references</b><br /><br /><i>save_error_references()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	error_references_df [label=<<b>error_references_df</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	save_references [label=<<b>save_references</b><br /><br /><i>save_references()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	save_error_references_from_open_citations [label=<<b>save_error_references_from_open_citations</b><br /><br /><i>save_error_references_from_open_citations()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	dois_to_query [label=<<b>dois_to_query: references_on_disk</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetch_references_with_crossref [label=<<b>fetch_references_with_crossref</b><br /><br /><i>tuple</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetch_references_with_opencitations [label=<<b>fetch_references_with_opencitations</b><br /><br /><i>tuple</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	doi [label=<<b>doi</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetch_references_with_crossref -> error_references
	_database_inputs [label=<<table border="0"><tr><td>database_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_database_inputs -> database
	fetched_references_df -> save_references_from_open_citations
	_save_references_from_open_citations_inputs [label=<<table border="0"><tr><td>path_save_references</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_save_references_from_open_citations_inputs -> save_references_from_open_citations
	doi -> cleaned_dois
	fetch_references_with_opencitations -> fetched_references_df
	fetch_references_with_crossref -> fetched_references
	error_references -> save_error_references
	_save_error_references_inputs [label=<<table border="0"><tr><td>saving_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_save_error_references_inputs -> save_error_references
	fetch_references_with_opencitations -> error_references_df
	fetched_references -> save_references
	_save_references_inputs [label=<<table border="0"><tr><td>saving_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_save_references_inputs -> save_references
	error_references_df -> save_error_references_from_open_citations
	_save_error_references_from_open_citations_inputs [label=<<table border="0"><tr><td>path_save_error_references</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_save_error_references_from_open_citations_inputs -> save_error_references_from_open_citations
	cleaned_dois -> dois_to_query
	dois_to_query -> fetch_references_with_crossref
	dois_to_query -> fetch_references_with_opencitations
	database -> doi
	subgraph cluster__legend {
		graph [fillcolor="#ffffff" fontname=helvetica label=Legend rank=same]
		config [fontname=Helvetica shape=note style=filled]
		input [fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
		function [fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
		materializer [fontname=Helvetica margin="0.15,0.1" shape=cylinder style=filled]
	}
}
