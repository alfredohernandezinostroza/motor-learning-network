// Dependency Graph
digraph {
	graph [compound=true concentrate=true rankdir=LR ranksep=0.4 style=filled]
	node [fillcolor="#ffffff"]
	references_on_disk [label=<<b>references_on_disk</b><br /><br /><i>True</i>> fontname=Helvetica shape=note style=filled]
	references_source [label=<<b>references_source</b><br /><br /><i>ReferencesSource.OPENCITATIONS</i>> fontname=Helvetica shape=note style=filled]
	save_references_from_open_citations [label=<<b>save_references_from_open_citations</b><br /><br /><i>save_references_from_open_citations()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	loaded_references_df [label=<<b>loaded_references_df</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetched_references_df [label=<<b>fetched_references_df: references_source</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	"loaded_error_references.loader" [label=<<b>loaded_error_references.loader</b><br /><br /><i>loaded_error_references()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	database [label=<<b>database</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	dois_to_query [label=<<b>dois_to_query: references_on_disk</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	"loaded_references_df.loader" [label=<<b>loaded_references_df.loader</b><br /><br /><i>loaded_references_df()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	cleaned_dois [label=<<b>cleaned_dois</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	error_references_df [label=<<b>error_references_df: references_source</b><br /><br /><i>DataFrame</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	loaded_references [label=<<b>loaded_references: references_on_disk</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetch_references_with_opencitations [label=<<b>fetch_references_with_opencitations: references_source</b><br /><br /><i>tuple</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	doi [label=<<b>doi</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	save_error_references_from_open_citations [label=<<b>save_error_references_from_open_citations</b><br /><br /><i>save_error_references_from_open_citations()</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=cylinder style="rounded,filled"]
	loaded_error_references [label=<<b>loaded_error_references</b><br /><br /><i>Series</i>> fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
	fetched_references_df -> save_references_from_open_citations
	loaded_references_df -> save_references_from_open_citations
	_save_references_from_open_citations_inputs [label=<<table border="0"><tr><td>references_file_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_save_references_from_open_citations_inputs -> save_references_from_open_citations
	"loaded_references_df.loader" -> loaded_references_df
	fetch_references_with_opencitations -> fetched_references_df
	"_loaded_error_references.loader_inputs" [label=<<table border="0"><tr><td>error_references_file_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	"_loaded_error_references.loader_inputs" -> "loaded_error_references.loader"
	_database_inputs [label=<<table border="0"><tr><td>database_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_database_inputs -> database
	cleaned_dois -> dois_to_query
	loaded_references -> dois_to_query
	loaded_error_references -> dois_to_query
	"_loaded_references_df.loader_inputs" [label=<<table border="0"><tr><td>references_file_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	"_loaded_references_df.loader_inputs" -> "loaded_references_df.loader"
	doi -> cleaned_dois
	fetch_references_with_opencitations -> error_references_df
	loaded_references_df -> loaded_references
	dois_to_query -> fetch_references_with_opencitations
	database -> doi
	error_references_df -> save_error_references_from_open_citations
	_save_error_references_from_open_citations_inputs [label=<<table border="0"><tr><td>error_references_file_path</td><td>Path</td></tr></table>> fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
	_save_error_references_from_open_citations_inputs -> save_error_references_from_open_citations
	"loaded_error_references.loader" -> loaded_error_references
	subgraph cluster__legend {
		graph [fillcolor="#ffffff" fontname=helvetica label=Legend rank=same]
		config [fontname=Helvetica shape=note style=filled]
		input [fontname=Helvetica margin=0.15 shape=rectangle style="filled,dashed"]
		function [fillcolor="#b4d8e4" fontname=Helvetica margin=0.15 shape=rectangle style="rounded,filled"]
		materializer [fontname=Helvetica margin="0.15,0.1" shape=cylinder style=filled]
	}
}
